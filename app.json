{
  "expo": {
    "name": "LearnifyTube",
    "slug": "learnify-mobile",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "learnify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1A"
    },
    "android": {
      "package": "com.learnifytube.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "versionCode": 8
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "./plugins/withAndroidTvSupport",
        {
          "banner": "./assets/tv-banner.png"
        }
      ],
      "./plugins/withAndroidCleartextNetwork",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "expo-sqlite",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "local-send-react-native",
          "organization": "nexttradingbot"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "learnify-mobile"
      },
      "apkUpdate": {
        "manifestUrl": "",
        "githubRepo": "hunght/learnify-mobile",
        "checkOnLaunch": true,
        "requestTimeoutMs": 10000
      }
    }
  }
}
